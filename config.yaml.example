transport: stdio

http:
  port: 8400
  host: "127.0.0.1"

auth:
  type: env                  # env | vault | azure-ad

  # Uncomment for Vault auth:
  # type: vault
  # vault:
  #   address: https://vault.example.com
  #   roleId: "..."          # or VAULT_ROLE_ID env var
  #   secretId: "..."        # or VAULT_SECRET_ID env var
  #   secretPath: secret/data/cloud-pilot   # KV v2 path (includes data/)

providers:
  - type: aws
    region: us-east-1
    mode: read-only
    allowedServices:
      - ec2
      - s3
      - iam
      - rds
      - lambda
      - ecs
      - sts
      - cloudwatch

  # - type: azure
  #   region: eastus
  #   mode: read-only

specs:
  dynamic: true
  cacheDir: "~/.cloud-pilot/cache"
  catalogTtlDays: 7
  specTtlDays: 30
  maxMemorySpecs: 10
  offline: false

sandbox:
  memoryLimitMB: 128
  timeoutMs: 120000

audit:
  type: file
  path: ./audit.json
