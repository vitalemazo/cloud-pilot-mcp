TRANSPORT=stdio
HTTP_PORT=8400
HTTP_HOST=127.0.0.1

# Auth: env | vault | azure-ad
# "env" auto-discovers credentials from CLI configs, shared credential files,
# SSO sessions, instance profiles, and environment variables (in that order).
# You only need to set env vars here if NOT using CLI-based auth.
AUTH_TYPE=env

# --- AWS ---
# Auto-discovered from: aws configure, aws sso login, ~/.aws/credentials, IMDS
# Only set these to override CLI-based auth:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# --- Azure ---
# Auto-discovered from: az login, Managed Identity, VS Code credential
# Only set these to override CLI-based auth:
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_SUBSCRIPTION_ID=

# --- GCP ---
# Auto-discovered from: gcloud auth application-default login, metadata server
# Only set these to override CLI-based auth:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_PROJECT_ID=

# --- Alibaba ---
# Auto-discovered from: aliyun configure, ~/.alibabacloud/credentials, ECS RAM role
# Only set these to override CLI-based auth:
# ALIBABA_CLOUD_ACCESS_KEY_ID=
# ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# ALIBABA_CLOUD_REGION=cn-hangzhou

# --- Vault (for auth.type=vault) ---
# VAULT_ADDR=
# VAULT_ROLE_ID=
# VAULT_SECRET_ID=

# --- Azure AD (for auth.type=azure-ad) ---
# Uses AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET above

# --- Dynamic Specs ---
CLOUD_PILOT_SPECS_DYNAMIC=true
CLOUD_PILOT_SPECS_OFFLINE=false
GITHUB_TOKEN=
