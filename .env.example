TRANSPORT=stdio
HTTP_PORT=8400
HTTP_HOST=127.0.0.1

# Auth: env | vault | azure-ad
AUTH_TYPE=env

# --- AWS (for auth.type=env) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- Azure (for auth.type=env) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_SUBSCRIPTION_ID=

# --- Vault (for auth.type=vault) ---
VAULT_ADDR=
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# --- Azure AD (for auth.type=azure-ad) ---
# Uses AZURE_TENANT_ID, AZURE_CLIENT_ID, AZURE_CLIENT_SECRET above

# --- Dynamic Specs ---
CLOUD_PILOT_SPECS_DYNAMIC=true
CLOUD_PILOT_SPECS_OFFLINE=false
GITHUB_TOKEN=
