{
  "name": "cloud-pilot-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI-driven cloud infrastructure management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cloud-pilot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "download-specs": "bash scripts/download-specs.sh",
    "build-catalogs": "tsx scripts/build-catalogs.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "quickjs-emscripten": "^0.31.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
