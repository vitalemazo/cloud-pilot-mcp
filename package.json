{
  "name": "cloud-pilot-mcp",
  "version": "0.1.0",
  "description": "MCP server for AI-driven cloud infrastructure management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "cloud-pilot-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "download-specs": "bash scripts/download-specs.sh",
    "build-catalogs": "tsx scripts/build-catalogs.ts"
  },
  "dependencies": {
    "@alicloud/credentials": "^2.4.4",
    "@aws-sdk/client-auto-scaling": "^3.1024.0",
    "@aws-sdk/client-cloudformation": "^3.1024.0",
    "@aws-sdk/client-cloudwatch": "^3.1024.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1024.0",
    "@aws-sdk/client-dynamodb": "^3.1024.0",
    "@aws-sdk/client-ec2": "^3.1024.0",
    "@aws-sdk/client-ecs": "^3.1024.0",
    "@aws-sdk/client-eks": "^3.1024.0",
    "@aws-sdk/client-elastic-load-balancing-v2": "^3.1024.0",
    "@aws-sdk/client-elasticache": "^3.1024.0",
    "@aws-sdk/client-iam": "^3.1024.0",
    "@aws-sdk/client-kms": "^3.1024.0",
    "@aws-sdk/client-lambda": "^3.1024.0",
    "@aws-sdk/client-rds": "^3.1024.0",
    "@aws-sdk/client-route-53": "^3.1024.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/client-secrets-manager": "^3.1024.0",
    "@aws-sdk/client-sns": "^3.1024.0",
    "@aws-sdk/client-sqs": "^3.1024.0",
    "@aws-sdk/client-sts": "^3.1024.0",
    "@aws-sdk/credential-providers": "^3.1024.0",
    "@azure/identity": "^4.13.1",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "google-auth-library": "^10.6.2",
    "quickjs-emscripten": "^0.31.0",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "author": {
    "name": "Vitale Mazo",
    "url": "https://github.com/vitalemazo"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vitalemazo/cloud-pilot-mcp.git"
  },
  "homepage": "https://github.com/vitalemazo/cloud-pilot-mcp",
  "license": "MIT"
}
